# ==============================================================================
# SoftCRM — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in values for local development.
#   cp .env.example .env
# ==============================================================================

# --- Application ---
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
LOG_LEVEL=debug

# --- Database (PostgreSQL 16) ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=softcrm
DB_PASSWORD=softcrm_dev_pass
DB_NAME=softcrm_dev
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# --- Redis 7 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- Authentication (JWT) ---
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Meilisearch ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=softcrm_dev_meili_key

# --- S3 / MinIO (Object Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=softcrm_minio
S3_SECRET_KEY=softcrm_minio_secret
S3_BUCKET=softcrm-uploads
S3_REGION=us-east-1

# --- Email (Transactional) ---
# Using SendGrid or Resend in production; stubbed locally
EMAIL_PROVIDER=console
SENDGRID_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@softcrm.local

# --- Twilio (VoIP / SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- OAuth (Email Sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- SSO (SAML / OIDC) ---
SSO_SAML_CERT=
SSO_SAML_ENTRY_POINT=
SSO_OIDC_ISSUER=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=

# --- Plaid (Banking Integration) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=softcrm-api

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
