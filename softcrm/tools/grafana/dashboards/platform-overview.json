{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le, route))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "p95 Latency by Route",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"softcrm-api\", status=~\"4..\"}[$__rate_interval])) by (module)",
          "legendFormat": "4xx — {{module}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"softcrm-api\", status=~\"5..\"}[$__rate_interval])) by (module)",
          "legendFormat": "5xx — {{module}}",
          "refId": "B"
        }
      ],
      "title": "Error Rate by Module",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"softcrm-api\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{job=\"softcrm-api\"}[$__rate_interval]))",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        }
      ],
      "title": "Overall 5xx Error Rate",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Connections & Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(nodejs_active_handles_total{job=\"softcrm-api\"})",
          "legendFormat": "Active Handles",
          "refId": "A"
        },
        {
          "expr": "sum(nodejs_active_requests_total{job=\"softcrm-api\"})",
          "legendFormat": "Active Requests",
          "refId": "B"
        }
      ],
      "title": "Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"softcrm-api\"}[$__rate_interval]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "title": "Request Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 7,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "avg(process_cpu_seconds_total{job=\"softcrm-api\"}) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "title": "API CPU Usage",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Database",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(prisma_client_queries_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(prisma_client_queries_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(prisma_client_queries_duration_seconds_bucket{job=\"softcrm-api\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "DB Query Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 9,
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"softcrm\", state=\"active\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_count{datname=\"softcrm\", state=\"idle\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "pg_settings_max_connections{datname=\"softcrm\"}",
          "legendFormat": "Max",
          "refId": "C"
        }
      ],
      "title": "DB Connection Pool",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "Redis & BullMQ",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "id": 10,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total{instance=~\".*softcrm.*\"} / (redis_keyspace_hits_total{instance=~\".*softcrm.*\"} + redis_keyspace_misses_total{instance=~\".*softcrm.*\"})",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ],
      "title": "Redis Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "id": 11,
      "targets": [
        {
          "expr": "redis_memory_used_bytes{instance=~\".*softcrm.*\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{instance=~\".*softcrm.*\"}",
          "legendFormat": "Max",
          "refId": "B"
        }
      ],
      "title": "Redis Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "normal" }, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "id": 12,
      "targets": [
        {
          "expr": "bull_queue_waiting{job=\"softcrm-api\"}",
          "legendFormat": "Waiting — {{queue}}",
          "refId": "A"
        },
        {
          "expr": "bull_queue_active{job=\"softcrm-api\"}",
          "legendFormat": "Active — {{queue}}",
          "refId": "B"
        },
        {
          "expr": "bull_queue_failed{job=\"softcrm-api\"}",
          "legendFormat": "Failed — {{queue}}",
          "refId": "C"
        },
        {
          "expr": "bull_queue_delayed{job=\"softcrm-api\"}",
          "legendFormat": "Delayed — {{queue}}",
          "refId": "D"
        }
      ],
      "title": "BullMQ Queue Depth",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 105,
      "title": "SLO Tracking",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percent",
          "min": 95,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 46 },
      "id": 13,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(http_requests_total{job=\"softcrm-api\", status=~\"5..\"}[30d])) / sum(rate(http_requests_total{job=\"softcrm-api\"}[30d])))) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "title": "30-Day Availability SLO (Target: 99.9%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 80,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 46 },
      "id": 14,
      "targets": [
        {
          "expr": "(sum(rate(http_request_duration_seconds_bucket{job=\"softcrm-api\", le=\"0.2\"}[30d])) / sum(rate(http_request_duration_seconds_count{job=\"softcrm-api\"}[30d]))) * 100",
          "legendFormat": "% < 200ms",
          "refId": "A"
        }
      ],
      "title": "30-Day Latency SLO (Target: 99% < 200ms)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2, "showPoints": "never" },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error Budget Remaining" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-blue", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 40 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 },
      "id": 15,
      "targets": [
        {
          "expr": "((0.001 - (sum(rate(http_requests_total{job=\"softcrm-api\", status=~\"5..\"}[30d])) / sum(rate(http_requests_total{job=\"softcrm-api\"}[30d])))) / 0.001) * 100",
          "legendFormat": "Error Budget Remaining",
          "refId": "A"
        }
      ],
      "title": "Error Budget Burn (30d)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["softcrm", "api", "slo"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SoftCRM — Platform Overview",
  "uid": "softcrm-platform-overview",
  "version": 1
