// ── Communications Module Schema ────────────────────────────────────────────────
// 2-way email sync, VoIP calling, email templates, and unified activity timeline.

// ── Enums ──────────────────────────────────────────────────────────────────────

enum ActivityType {
  EMAIL
  CALL
  MEETING
  NOTE
  SMS

  @@schema("comms")
}

enum ActivityDirection {
  INBOUND
  OUTBOUND

  @@schema("comms")
}

enum EmailSyncProvider {
  GMAIL
  OUTLOOK

  @@schema("comms")
}

enum EmailSyncStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED

  @@schema("comms")
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELLED

  @@schema("comms")
}

// ── Models ─────────────────────────────────────────────────────────────────────

/// Unified activity record — every email, call, meeting, note, or SMS is an Activity.
model Activity {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @db.Uuid
  type        ActivityType
  direction   ActivityDirection
  contactId   String?           @db.Uuid
  dealId      String?           @db.Uuid
  ticketId    String?           @db.Uuid
  accountId   String?           @db.Uuid
  subject     String?
  body        String?           @db.Text
  metadata    Json?
  timestamp   DateTime          @default(now())
  createdBy   String            @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  callLog     CallLog?

  @@index([tenantId, contactId, timestamp])
  @@index([tenantId, dealId, timestamp])
  @@index([tenantId, ticketId, timestamp])
  @@index([tenantId, accountId, timestamp])
  @@index([tenantId, timestamp])
  @@schema("comms")
}

/// Per-user email sync configuration (Gmail / Outlook).
model EmailSync {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  userId        String            @db.Uuid
  provider      EmailSyncProvider
  accessToken   String            @db.Text
  refreshToken  String            @db.Text
  lastSyncAt    DateTime?
  status        EmailSyncStatus   @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([tenantId, userId, provider])
  @@schema("comms")
}

/// Reusable email template with merge-field support.
model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  subject     String
  bodyHtml    String   @db.Text
  mergeFields String[] @default([])
  isActive    Boolean  @default(true)
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)

  @@unique([tenantId, name])
  @@schema("comms")
}

/// Call log attached to an Activity of type CALL.
model CallLog {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  activityId  String     @unique @db.Uuid
  provider    String     @default("twilio")
  callSid     String?
  fromNumber  String
  toNumber    String
  duration    Int        @default(0) // seconds
  recordingUrl String?
  status      CallStatus @default(INITIATED)
  createdAt   DateTime   @default(now())

  activity    Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([tenantId, callSid])
  @@schema("comms")
}

// ── Meeting Scheduler ─────────────────────────────────────────────────────────

model AvailabilitySlot {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time") @db.VarChar(5)
  endTime     String   @map("end_time") @db.VarChar(5)
  timezone    String   @default("UTC") @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, userId])
  @@map("availability_slots")
  @@schema("comms")
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@schema("comms")
}

model BookedMeeting {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  hostUserId    String        @map("host_user_id") @db.Uuid
  contactId     String?       @map("contact_id") @db.Uuid
  dealId        String?       @map("deal_id") @db.Uuid
  title         String        @db.VarChar(255)
  description   String?       @db.Text
  startTime     DateTime      @map("start_time")
  endTime       DateTime      @map("end_time")
  timezone      String        @default("UTC") @db.VarChar(50)
  location      String?       @db.VarChar(500)
  meetingUrl    String?       @map("meeting_url") @db.VarChar(500)
  status        MeetingStatus @default(PENDING)
  guestEmail    String?       @map("guest_email") @db.VarChar(255)
  guestName     String?       @map("guest_name") @db.VarChar(200)
  bookingLink   String?       @map("booking_link") @db.VarChar(100)
  notes         String?       @db.Text
  cancelledAt   DateTime?     @map("cancelled_at")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([tenantId, hostUserId, startTime])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@map("booked_meetings")
  @@schema("comms")
}

// ── Live Chat ─────────────────────────────────────────────────────────────────

enum ChatSessionStatus {
  WAITING
  ACTIVE
  CLOSED

  @@schema("comms")
}

model ChatSession {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  visitorId   String            @map("visitor_id") @db.VarChar(100)
  visitorName String?           @map("visitor_name") @db.VarChar(200)
  visitorEmail String?          @map("visitor_email") @db.VarChar(255)
  agentId     String?           @map("agent_id") @db.Uuid
  contactId   String?           @map("contact_id") @db.Uuid
  status      ChatSessionStatus @default(WAITING)
  startedAt   DateTime          @default(now()) @map("started_at")
  closedAt    DateTime?         @map("closed_at")
  rating      Int?
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  messages    ChatMessage[]

  @@index([tenantId, status])
  @@index([tenantId, agentId])
  @@index([tenantId, visitorId])
  @@map("chat_sessions")
  @@schema("comms")
}

model ChatMessage {
  id            String      @id @default(uuid()) @db.Uuid
  chatSessionId String      @map("chat_session_id") @db.Uuid
  senderType    String      @map("sender_type") @db.VarChar(20)
  senderId      String?     @map("sender_id") @db.Uuid
  content       String      @db.Text
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at")

  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
  @@schema("comms")
}
