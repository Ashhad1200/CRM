// ── Analytics Module Schema ───────────────────────────────────────────────────
// Configurable dashboards with widgets, custom report builder, AI revenue
// forecasting, and anomaly detection.

// ── Enums ──────────────────────────────────────────────────────────────────────

enum WidgetType {
  CHART
  KPI
  TABLE
  FUNNEL

  @@schema("analytics")
}

enum ForecastType {
  REVENUE
  PIPELINE

  @@schema("analytics")
}

// ── Models ─────────────────────────────────────────────────────────────────────

/// Configurable dashboard owned by a user, with layout stored as JSON.
model Dashboard {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String   @db.VarChar(255)
  ownerId   String   @db.Uuid
  isDefault Boolean  @default(false)
  layout    Json?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  widgets Widget[]

  @@unique([tenantId, name])
  @@index([tenantId, ownerId])
  @@schema("analytics")
}

/// Individual widget inside a dashboard (chart, KPI card, table, or funnel).
model Widget {
  id          String     @id @default(uuid()) @db.Uuid
  dashboardId String     @db.Uuid
  type        WidgetType
  config      Json
  position    Json
  createdAt   DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(3)

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@schema("analytics")
}

/// Saved report definition with optional scheduling.
model SavedReport {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  name               String   @db.VarChar(255)
  ownerId            String   @db.Uuid
  fieldSelection     Json
  groupBy            String?  @db.VarChar(255)
  aggregation        String?  @db.VarChar(50)
  filters            Json?
  scheduleFrequency  String?  @db.VarChar(50)
  scheduleRecipients String[] @db.VarChar(255)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  @@unique([tenantId, name])
  @@index([tenantId, ownerId])
  @@schema("analytics")
}

/// Revenue or pipeline forecast generated by linear regression.
model Forecast {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  type           ForecastType
  period         String       @db.VarChar(50)
  predictedValue Decimal      @db.Decimal(18, 2)
  confidenceLow  Decimal      @db.Decimal(18, 2)
  confidenceHigh Decimal      @db.Decimal(18, 2)
  modelVersion   String       @db.VarChar(50)
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)

  @@index([tenantId, type])
  @@schema("analytics")
}
