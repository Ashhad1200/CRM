// ── Platform Module Schema ─────────────────────────────────────────────────────
// Tenants, Users, Roles, Permissions, Audit Logs, Custom Fields, Tokens

// ── Tenant ─────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  domain    String?  @db.VarChar(255)
  status    TenantStatus @default(ACTIVE)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  roles     Role[]
  teams     Team[]
  auditLogs AuditLog[]
  customFieldDefs CustomFieldDef[]

  @@map("tenants")
  @@schema("platform")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL

  @@schema("platform")
}

// ── User ───────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  email         String   @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  firstName     String   @map("first_name") @db.VarChar(100)
  lastName      String   @map("last_name") @db.VarChar(100)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  phone         String?  @db.VarChar(50)
  status        UserStatus @default(ACTIVE)
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  mfaSecret     String?  @map("mfa_secret") @db.VarChar(255)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid
  version       Int      @default(1)

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  userTeams     UserTeam[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
  @@schema("platform")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  LOCKED

  @@schema("platform")
}

// ── Role ───────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  version     Int      @default(1)

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles           UserRole[]
  modulePermissions   ModulePermission[]
  entityPermissions   EntityPermission[]
  fieldPermissions    FieldPermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
  @@schema("platform")
}

// ── User ↔ Role (M2M) ─────────────────────────────────────────────────────────

model UserRole {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  roleId   String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") @db.Uuid

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
  @@schema("platform")
}

// ── Module Permission ──────────────────────────────────────────────────────────

model ModulePermission {
  id          String      @id @default(uuid()) @db.Uuid
  roleId      String      @map("role_id") @db.Uuid
  module      String      @db.VarChar(50)
  accessLevel AccessLevel @map("access_level")

  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("module_permissions")
  @@schema("platform")
}

// ── Entity Permission ──────────────────────────────────────────────────────────

model EntityPermission {
  id        String         @id @default(uuid()) @db.Uuid
  roleId    String         @map("role_id") @db.Uuid
  module    String         @db.VarChar(50)
  entity    String         @db.VarChar(50)
  scope     OwnershipScope @default(OWN)
  canCreate Boolean        @default(false) @map("can_create")
  canRead   Boolean        @default(false) @map("can_read")
  canUpdate Boolean        @default(false) @map("can_update")
  canDelete Boolean        @default(false) @map("can_delete")

  role      Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, entity])
  @@map("entity_permissions")
  @@schema("platform")
}

// ── Field Permission ───────────────────────────────────────────────────────────

model FieldPermission {
  id       String  @id @default(uuid()) @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  module   String  @db.VarChar(50)
  entity   String  @db.VarChar(50)
  field    String  @db.VarChar(100)
  visible  Boolean @default(true)
  editable Boolean @default(false)

  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, entity, field])
  @@map("field_permissions")
  @@schema("platform")
}

// ── Team ───────────────────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100)
  managerId String?  @map("manager_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members   UserTeam[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("teams")
  @@schema("platform")
}

// ── User ↔ Team (M2M) ─────────────────────────────────────────────────────────

model UserTeam {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  teamId String @map("team_id") @db.Uuid

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("user_teams")
  @@schema("platform")
}

// ── Audit Log ──────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  actorId      String   @map("actor_id") @db.Uuid
  ip           String?  @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  module       String   @db.VarChar(50)
  entity       String   @db.VarChar(50)
  recordId     String   @map("record_id") @db.Uuid
  action       AuditAction
  changes      Json     @default("[]")
  previousHash String?  @map("previous_hash") @db.VarChar(64)
  hash         String   @db.VarChar(64)
  timestamp    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, timestamp])
  @@index([tenantId, module, entity])
  @@index([tenantId, recordId])
  @@map("audit_logs")
  @@schema("platform")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE

  @@schema("platform")
}

// ── Refresh Token ──────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(255)
  family    String    @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ip        String?   @db.VarChar(45)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
  @@schema("platform")
}

// ── Custom Field Definition ────────────────────────────────────────────────────

model CustomFieldDef {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  module     String    @db.VarChar(50)
  entity     String    @db.VarChar(50)
  fieldName  String    @map("field_name") @db.VarChar(100)
  fieldType  FieldType @map("field_type")
  label      String    @db.VarChar(200)
  required   Boolean   @default(false)
  options    Json?     // For select/multiselect types
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values     CustomFieldValue[]

  @@unique([tenantId, module, entity, fieldName])
  @@index([tenantId, module, entity])
  @@map("custom_field_defs")
  @@schema("platform")
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  URL
  EMAIL
  PHONE
  TEXTAREA

  @@schema("platform")
}

// ── Custom Field Value ─────────────────────────────────────────────────────────

model CustomFieldValue {
  id         String   @id @default(uuid()) @db.Uuid
  fieldDefId String   @map("field_def_id") @db.Uuid
  recordId   String   @map("record_id") @db.Uuid
  value      String   @db.Text

  fieldDef   CustomFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  @@unique([fieldDefId, recordId])
  @@index([recordId])
  @@map("custom_field_values")
  @@schema("platform")
}

// ── Workflow Definition ─────────────────────────────────────────────────────────

model Workflow {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  name          String         @db.VarChar(255)
  description   String?        @db.VarChar(1000)
  trigger       Json           // { type: 'event' | 'cron', event?: string, cron?: string }
  conditions    Json           @default("[]") // [{ field, operator, value, logic }]
  actions       Json           @default("[]") // [{ type, config }]
  status        WorkflowStatus @default(INACTIVE)
  loopLimit     Int            @default(5) @map("loop_limit")
  createdBy     String         @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  executions    WorkflowExecution[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@map("workflows")
  @@schema("platform")
}

enum WorkflowStatus {
  ACTIVE
  INACTIVE

  @@schema("platform")
}

// ── Workflow Execution ─────────────────────────────────────────────────────────

model WorkflowExecution {
  id            String              @id @default(uuid()) @db.Uuid
  workflowId    String              @map("workflow_id") @db.Uuid
  triggerEvent  String              @map("trigger_event") @db.VarChar(100)
  triggerPayload Json?              @map("trigger_payload")
  status        WorkflowExecStatus  @default(RUNNING)
  actionResults Json                @default("[]") @map("action_results")
  error         String?             @db.Text
  startedAt     DateTime            @default(now()) @map("started_at")
  finishedAt    DateTime?           @map("finished_at")

  workflow      Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, startedAt])
  @@map("workflow_executions")
  @@schema("platform")
}

enum WorkflowExecStatus {
  RUNNING
  COMPLETED
  FAILED

  @@schema("platform")
}

// ── Outbox (for event bus reliability) ─────────────────────────────────────────

model Outbox {
  id          String   @id @default(uuid()) @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(100)
  aggregateId String   @map("aggregate_id") @db.Uuid
  payload     Json
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([published, createdAt])
  @@map("outbox")
  @@schema("platform")
}
